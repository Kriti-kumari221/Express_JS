<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Comments</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#f4f6f9;
            padding:40px;
        }

        h1{
            text-align:center;
            color:#333;
            margin-bottom:25px;
        }

        .add-btn{
            display:inline-block;
            margin-bottom:20px;
            background:#007bff;
            color:white;
            text-decoration:none;
            padding:12px 18px;
            border-radius:8px;
        }

        .card{
            background:white;
            padding:20px;
            margin:20px auto;
            width:600px;
            border-radius:10px;
            box-shadow:0 5px 15px rgba(0,0,0,.1);
        }

        .actions{
            margin-top:15px;
        }

        .actions a,
        .actions button{
            padding:8px 15px;
            text-decoration:none;
            border:none;
            border-radius:6px;
            color:white;
            cursor:pointer;
            margin-right:10px;
        }

        .show{
            background:#17a2b8;
        }

        .edit{
            background:#ffc107;
            color:black;
        }

        .delete{
            background:#dc3545;
        }
    </style>

</head>
<body>

<h1>💬 All Comments</h1>

<a href="/comments/new" class="add-btn">➕ Add New Comment</a>

<% for(const comment of comments){ %>

<div class="card">
    <h3>👤 <%= comment.user %></h3>
    <p><%= comment.text %></p>
    <div class="actions">
        <a class="show" href="/comments/<%= comment._id %>">Show</a>
        <a class="edit" href="/comments/<%= comment._id %>/edit">Edit</a>
        <form action="/comments/<%= comment._id %>?_method=DELETE"
              method="POST"
              style="display:inline;">
            <button class="delete">Delete</button>

        </form>
        <form action="/comments/<%= comment._id %>/like?_method=PATCH" method="POST">
    <button><h4 style="color: #333;">❤️ Likes: <%= comment.likes %></h4></button>
</form>
    </div>
</div>

<% } %>

</body>
</html>